# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://allfix:secret@localhost:5432/allfix?sslmode=disable

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRY_HOURS=72
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Bootstrap (keep secret, never expose publicly)
ADMIN_BOOTSTRAP_SECRET=local-dev-bootstrap-secret

# Named environments (used by bootstrap script --env flag)
BASE_URL_LOCAL=http://localhost:8080
BOOTSTRAP_SECRET_LOCAL=local-dev-bootstrap-secret

BASE_URL_STAGING=https://staging.allfix.example.com

BASE_URL_PROD=https://allfix.example.com
BOOTSTRAP_SECRET_PROD=
